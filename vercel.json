{
  "functions": {
    "backend/server.js": {
      "runtime": "nodejs18.x",
      "maxDuration": 120
    }
  },
  "rewrites": [
    {
      "source": "/api/generate-video",
      "destination": "/backend/server.js"
    },
    {
      "source": "/api/status/:id",
      "destination": "/backend/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/index.html"
    }
  ]
}
