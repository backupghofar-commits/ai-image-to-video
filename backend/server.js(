require('dotenv').config();
const express = require('express');
const cors = require('cors');
const axios = require('axios');
const multer = require('multer');

const app = express();
app.use(cors({ origin: '*' }));
app.use(express.json({ limit: '50mb' }));
app.use(express.urlencoded({ extended: true, limit: '50mb' }));

const upload = multer({ storage: multer.memoryStorage() });
const predictionStatus = new Map();

app.post('/generate-video', upload.single('image'), async (req, res) => {
  try {
    const prompt = req.body.prompt;
    const imageBuffer = req.file?.buffer;
    
    if (!imageBuffer || !prompt?.trim()) {
      return res.status(400).json({ error: 'Image & prompt required' });
    }

    const prediction = await axios.post('https://api.replicate.com/v1/predictions', {
      version: "ac95f0cb7d533cd07a2c5e41f1a30b96d31696b6aa5dd550cf78b13eac7e94b9",
      input: {
        image: `data:image/jpeg;base64,${imageBuffer.toString('base64')}`,
        prompt: prompt.trim(),
        guidance_scale: 7.5
      }
    }, {
      headers: {
        'Authorization': `Token ${process.env.REPLICATE_API_TOKEN}`,
        'Content-Type': 'application/json'
      }
    });

    const id = prediction.data.id;
    predictionStatus.set(id, { status: 'starting' });
    
    res.json({ id, status: 'starting' });
  } catch (error) {
    res.status(500).json({ 
      error: error.response?.data?.error || error.message 
    });
  }
});

app.get('/status/:id', async (req, res) => {
  const { id } = req.params;
  try {
    const { data } = await axios.get(`https://api.replicate.com/v1/predictions/${id}`, {
      headers: { 'Authorization': `Token ${process.env.REPLICATE_API_TOKEN}` }
    });
    res.json({ status: data.status, output: data.output });
  } catch (error) {
    res.status(500).json({ error: 'Status check failed' });
  }
});

module.exports = app;
